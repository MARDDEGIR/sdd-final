extends: default
ignore: |
  charts/
  .github/
rules:
  line-length:
    max: 300
    level: warning
  truthy:
    allowed-values: ["true", "false", "yes", "no"]
    check-keys: false
  comments:
    min-spaces-from-content: 1
    level: warning
  braces:
    max-spaces-inside: 1
    level: warning
